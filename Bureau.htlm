color:#009245;
}

h2{
color:#009245;
border-left:5px solid #FFD700;
padding-left:10px;
}

.organigramme{
background:#f8f8f8;
padding:25px;
border-radius:15px;
font-weight:bold;
line-height:2;
text-align:center;
font-size:18px;
}

footer{
background:#003b1f;
color:white;
padding:30px;
text-align:center;
border-radius:20px;
}

.whatsapp{
position:fixed;
bottom:20px;
right:20px;
background:#25D366;
width:65px;
height:65px;
border-radius:50%;
display:flex;
justify-content:center;
align-items:center;
font-size:35px;
text-decoration:none;
color:white;
box-shadow:0 5px 15px rgba(0,0,0,0.3);
}

@media(max-width:900px){

